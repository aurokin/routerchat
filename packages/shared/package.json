{
    "name": "@routerchat/shared",
    "version": "0.2.0",
    "private": true,
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,jsx,ts,tsx,json,css,md}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,jsx,ts,tsx,json,css,md}\"",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "health": "bun run format && bun run typecheck && bun run lint && bun run test"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "eslint": "^10.3.0",
        "msw": "^2.14.5",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
