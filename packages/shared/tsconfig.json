{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["ES2020", "DOM"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "jsx": "preserve"
    },
    "include": ["src/**/*"]
}
