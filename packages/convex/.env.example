# RouterChat (Convex CLI) Environment Variables
#
# This file is ONLY for the Convex CLI (codegen/dev) to select which deployment
# to target. It is not used by the Convex runtime itself.
#
# Convex usually writes `packages/convex/.env.local` automatically when you run:
#
#   bun run --cwd packages/convex dev -- --configure existing --once
#
# You generally only need CONVEX_DEPLOYMENT. CONVEX_URL is auto-populated.

# CONVEX_DEPLOYMENT=dev:your-deployment-name
