{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "jsx": "preserve",
        "types": ["bun", "vite/client"]
    },
    "include": ["convex/**/*", "vitest.config.ts"]
}
