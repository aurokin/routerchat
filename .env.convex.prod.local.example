# Convex runtime env vars (Production)
#
# Create a gitignored copy at repo root:
#   .env.convex.prod.local
#
# Apply via:
#   bun run convex:env -- --env prod --deployment prod:<your-deployment>
#
# Note: CONVEX_DEPLOYMENT is used as the target for the CLI, but is NOT set as a runtime env var.

CONVEX_DEPLOYMENT=prod:<your-deployment-name>

SITE_URL=https://www.example.com

AUTH_GOOGLE_ID=...
AUTH_GOOGLE_SECRET=...

# Generate and keep these stable per deployment/environment:
#   bun run convex:gen-secrets
# JWKS=...
# JWT_PRIVATE_KEY=...
# ENCRYPTION_KEY=...
