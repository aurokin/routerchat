# Railway service variables (Preview)
#
# Create a gitignored copy at repo root:
#   .env.railway.preview.local
#
# Apply via:
#   bun run railway:env -- --env preview

# Optional: override defaults used by the script
# RAILWAY_SERVICE=routerchat-web-preview
# RAILWAY_ENV=preview

NEXT_PUBLIC_CONVEX_URL=https://<preview-convex-deployment>.convex.cloud

# Optional: canonical host enforcement in web middleware.
# Set this for preview consistency (same host as preview domain).
# CANONICAL_HOST=preview.example.com

# Debug only: disable CSP (middleware will still set other security headers).
# Prefer fixing the underlying CSP issue instead.
# If applying via `bun run railway:env -- --env preview`, you must pass `--allow-disable-csp`.
# DISABLE_CSP=true
