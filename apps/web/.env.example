# RouterChat (Web) Environment Variables
#
# RouterChat can run in local-only mode with no env vars.
# To enable cloud sync, set NEXT_PUBLIC_CONVEX_URL.

# Convex (optional)
# NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# Security / debugging (optional)
# Set to force a canonical host redirect (e.g. example.com -> www.example.com).
# CANONICAL_HOST=www.example.com
#
# Set to "true" to disable CSP headers in Next middleware.
# Do not enable this in production.
# DISABLE_CSP=true
