# Railway service variables (Production)
#
# Create a gitignored copy at repo root:
#   .env.railway.prod.local
#
# Apply via:
#   bun run railway:env -- --env prod

# Optional: override defaults used by the script
# RAILWAY_SERVICE=routerchat-web
# RAILWAY_ENV=production

NEXT_PUBLIC_CONVEX_URL=https://<prod-convex-deployment>.convex.cloud

# Optional: canonical host enforcement in web middleware.
# Use this when serving both apex and www and you want to force canonical origin.
# CANONICAL_HOST=www.example.com
