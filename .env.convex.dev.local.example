# Convex runtime env vars (Local Development)
#
# Create a gitignored copy at repo root:
#   .env.convex.dev.local
#
# Apply via:
#   bun run convex:env -- --env dev
#
# Note: CONVEX_DEPLOYMENT is used as the target for the CLI, but is NOT set as a runtime env var.

CONVEX_DEPLOYMENT=dev:<your-dev-deployment-name>

# Used by Convex Auth to validate redirects back to the app domain.
# apps/web runs on port 4040 in this repo.
SITE_URL=http://localhost:4040

# Google OAuth (must match the OAuth client that has the Convex redirect URI registered)
AUTH_GOOGLE_ID=...
AUTH_GOOGLE_SECRET=...

# Generate and keep these stable per deployment/environment:
#   bun run convex:gen-secrets
# JWKS=...
# JWT_PRIVATE_KEY=...
# ENCRYPTION_KEY=...

